{
  "name": "instagram-automation-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npx vite build --config ./vite.config.ts",
    "preview": "vite preview",
    "db:types": "npx supabase gen types typescript --project-id uromexjprcrjfmhkmgxa > src/lib/database.types.ts",
    "db:status": "npx supabase status",
    "check:ports": "lsof -i :8080 || echo 'Port 8080 is available'",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf node_modules"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.56.1",
    "@tauri-apps/api": "^2.11.1",
    "axios": "^1.10.0",
    "cli": "^1.0.1",
    "debug": "^4.4.1",
    "dotenv": "^16.6.1",
    "supabase": "^2.39.2",
    "tailwind": "^4.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.47",
    "@playwright/test": "^1.56.1",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^20.0.0",
    "@vitest/ui": "^4.1.9",
    "autoprefixer": "^10.4.14",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "jsdom": "^29.1.1",
    "nodemon": "^3.1.10",
    "postcss": "^8.4.24",
    "svelte": "^4.2.20",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0",
    "cloudflared": "2025.7.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/instagram-automation-dashboard.git"
  },
  "keywords": [
    "instagram",
    "automation",
    "react",
    "vite",
    "typescript",
    "cloudflare",
    "webhook",
    "meta-api",
    "supabase",
    "n8n-workflows"
  ],
  "author": "",
  "license": "MIT",
  "description": "Instagram automation dashboard with Meta API integration, Supabase database, and Cloudflare zero-trust tunneling"
}
