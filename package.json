{
  "name": "instagram-automation-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npx vite build --config ./vite.config.ts",
    "preview": "vite preview",
    "db:types": "npx supabase gen types typescript --project-id uromexjprcrjfmhkmgxa > src/lib/database.types.ts",
    "db:status": "npx supabase status",
    "check:ports": "lsof -i :8080 || echo 'Port 8080 is available'",
    "clean": "rm -rf node_modules"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@babel/core": "^7.28.0",
    "@radix-ui/react-focus-scope": "^1.1.7",
    "@supabase/supabase-js": "^2.56.1",
    "@tanstack/react-query": "^5.85.6",
    "axios": "^1.10.0",
    "cli": "^1.0.1",
    "debug": "^4.4.1",
    "dotenv": "^16.6.1",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.525.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.7.1",
    "recharts": "^2.7.2",
    "supabase": "^2.39.2",
    "tailwind": "^4.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.47",
    "@playwright/test": "^1.56.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.3.7",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.14",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "nodemon": "^3.1.10",
    "postcss": "^8.4.24",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0",
    "cloudflared": "2025.7.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/instagram-automation-dashboard.git"
  },
  "keywords": [
    "instagram",
    "automation",
    "react",
    "vite",
    "typescript",
    "cloudflare",
    "webhook",
    "meta-api",
    "supabase",
    "n8n-workflows"
